# Salin file ini menjadi .env lalu isi nilainya
# JANGAN commit file .env ke GitHub!

# Secret key untuk session Flask
# Generate baru dengan: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ganti-dengan-secret-key-yang-panjang-dan-random

# Environment: development atau production
FLASK_ENV=development

# Database (uncomment untuk MariaDB nanti di Agustus)
# DATABASE_URL=mysql+pymysql://siadik_user:password@localhost/siadik
